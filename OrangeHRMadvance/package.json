{
  "name": "orangehrm-playwright-advance",
  "version": "1.0.0",
  "description": "Advanced Playwright E2E automation framework for OrangeHRM",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:smoke": "playwright test --grep @smoke",
    "test:pim": "playwright test --grep @pim",
    "test:admin": "playwright test --grep @admin",
    "test:cross-browser": "playwright test --grep @cross-browser",
    "test:visual": "playwright test --grep @visual",
    "test:chromium": "playwright test --project chromium",
    "test:firefox": "playwright test --project firefox",
    "test:webkit": "playwright test --project webkit",
    "test:mobile": "playwright test --project 'Mobile Chrome' --project 'Mobile Safari'",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report",
    "lint": "eslint src/ tests/ --ext .ts",
    "lint:fix": "eslint src/ tests/ --ext .ts --fix",
    "format": "prettier --write src/ tests/ playwright.config.ts tsconfig.json",
    "format:check": "prettier --check src/ tests/ playwright.config.ts tsconfig.json",
    "quality": "npm run lint && npm run format:check",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "percy:visual": "percy exec -- npx playwright test tests/visual/visual-regression.spec.ts --grep @visual",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@percy/cli": "^1.31.14",
    "@percy/playwright": "^1.1.0",
    "@playwright/test": "^1.44.0",
    "@types/node": "^20.12.7",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "allure-commandline": "^2.13.11",
    "allure-playwright": "^2.0.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "typescript": "^5.4.5"
  }
}
