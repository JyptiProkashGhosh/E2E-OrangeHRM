# OrangeHRM E2E Test Environment Configuration
# Copy this file to .env.local and update values for your environment

# Application
ENVIRONMENT=demo
BASE_URL=https://opensource-demo.orangehrmlive.com

# Authentication Credentials
ADMIN_USERNAME=Admin
ADMIN_PASSWORD=admin123

# Invalid test credentials (for negative testing)
INVALID_USERNAME=WrongAdmin
INVALID_PASSWORD=wrongPassword123

# Timeouts (in milliseconds)
DEFAULT_TIMEOUT=15000
ACTION_TIMEOUT=30000
NAVIGATION_TIMEOUT=60000

# Percy Visual Regression (optional)
PERCY_TOKEN=your_percy_token_here
PERCY_PROJECT=orangehrm-e2e

# Database Configuration (for future use)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=password
DB_NAME=orangehrm
